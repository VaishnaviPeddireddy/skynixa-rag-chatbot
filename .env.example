# ─── Low-RAM mode (default — no Ollama, no C++ build tools) ───
AI_PROVIDER=lightweight
HF_EMBEDDING_MODEL=Xenova/paraphrase-MiniLM-L3-v2

# Smaller chunks = less RAM during ingest and search
RAG_TOP_K=2
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# ─── Optional: Google Search (external sources) ───
# ENABLE_GOOGLE_SEARCH=true
# GOOGLE_SEARCH_API_KEY=your_google_api_key
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id
# GOOGLE_SEARCH_MAX_RESULTS=2

# Setup:
# 1. Create a Programmable Search Engine: https://programmablesearchengine.google.com
# 2. Enable "Search the entire web"
# 3. Get API key: https://developers.google.com/custom-search/v1/overview
# Free tier: 100 searches/day

# ─── Optional: full Ollama mode (needs 8+ GB RAM + ollama pull) ───
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=phi3
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
